{
  "name": "forge-ai",
  "displayName": "Forge AI",
  "description": "AI chat routed through your own Azure AI Foundry endpoint — private, self-managed, all inference in your tenant",
  "version": "0.3.1",
  "publisher": "robpitcher",
  "repository": {
    "type": "git",
    "url": "https://github.com/robpitcher/forge"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.93.0",
    "node": ">=20.19.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [],
  "icon": "resources/icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forge",
          "title": "Forge",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "forge": [
        {
          "type": "webview",
          "id": "forge.chatView",
          "name": "AI Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "forge.openSettings",
        "title": "Forge Settings",
        "icon": "$(gear)"
      },
      {
        "command": "forge.showHistory",
        "title": "Conversation History",
        "icon": "$(history)"
      },
      {
        "command": "forge.signIn",
        "title": "Forge: Sign In"
      },
      {
        "command": "forge.attachSelection",
        "title": "Forge: Attach Selection"
      },
      {
        "command": "forge.attachFile",
        "title": "Forge: Attach File"
      },
      {
        "command": "forge.explain",
        "title": "Forge: Explain with Forge"
      },
      {
        "command": "forge.fix",
        "title": "Forge: Fix with Forge"
      },
      {
        "command": "forge.tests",
        "title": "Forge: Write Tests with Forge"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "forge.openSettings",
          "when": "view == forge.chatView",
          "group": "navigation"
        },
        {
          "command": "forge.showHistory",
          "when": "view == forge.chatView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Forge",
      "properties": {
        "forge.copilot.endpoint": {
          "type": "string",
          "default": "",
          "description": "Azure AI Foundry endpoint URL (e.g., https://myresource.services.ai.azure.com/)"
        },
        "forge.copilot.models": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Available model deployments for the model selector. Values must match your Azure AI Foundry model deployment name (not the model name, as they can differ). The first entry is the default active model."
        },
        "forge.copilot.wireApi": {
          "type": "string",
          "default": "completions",
          "enum": [
            "completions",
            "responses"
          ],
          "description": "API format: 'completions' or 'responses'"
        },
        "forge.copilot.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to Copilot CLI binary (if not on PATH)"
        },
        "forge.copilot.authMethod": {
          "type": "string",
          "enum": [
            "entraId",
            "apiKey"
          ],
          "default": "entraId",
          "description": "Authentication method. 'entraId' uses DefaultAzureCredential (recommended). 'apiKey' uses a static API key.",
          "enumDescriptions": [
            "Use Azure Entra ID (DefaultAzureCredential) for authentication. Recommended for environments with Azure AD.",
            "Use a static API key stored in VS Code SecretStorage. Use for environments without Entra ID."
          ]
        },
        "forge.copilot.autoApproveTools": {
          "type": "boolean",
          "default": false,
          "description": "Automatically approve tool executions without confirmation. Enable only in trusted environments."
        },
        "forge.copilot.systemMessage": {
          "type": "string",
          "default": "",
          "description": "Custom system message to append to the default Copilot system prompt. Leave empty to use the SDK default.",
          "editPresentation": "multilineText"
        },
        "forge.copilot.tools.shell": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Shell tool (execute terminal commands)"
        },
        "forge.copilot.tools.read": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Read tool (read file contents)"
        },
        "forge.copilot.tools.write": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Write tool (write/edit files)"
        },
        "forge.copilot.tools.url": {
          "type": "boolean",
          "default": false,
          "description": "Enable the URL tool (fetch web content). Disabled by default for restricted environments."
        },
        "forge.copilot.tools.mcp": {
          "type": "boolean",
          "default": true,
          "description": "Enable MCP tool support (Model Context Protocol servers)"
        },
        "forge.copilot.mcpAllowRemote": {
          "type": "boolean",
          "default": false,
          "description": "Allow remote (HTTP/SSE) MCP servers. Enable only for privately networked MCP servers within your network. Disabled by default for network safety."
        },
        "forge.copilot.mcpServers": {
          "type": "object",
          "default": {},
          "description": "MCP (Model Context Protocol) server configurations. Each key is a server name. Local servers use { command, args?, env? }. Remote servers use { url, headers? } (requires allowRemoteMcp).",
          "additionalProperties": {
            "oneOf": [
              {
                "type": "object",
                "required": [
                  "command"
                ],
                "properties": {
                  "command": {
                    "type": "string",
                    "description": "Command to start the local MCP server process"
                  },
                  "args": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Arguments to pass to the server command"
                  },
                  "env": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    },
                    "description": "Environment variables for the server process"
                  }
                }
              },
              {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "URL of the remote MCP server (HTTP/SSE endpoint)"
                  },
                  "headers": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    },
                    "description": "HTTP headers to include in requests to the remote server"
                  }
                }
              }
            ]
          }
        }
      }
    }
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@github/copilot-sdk": "0.1.26",
    "dompurify": "^3.3.1",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.3",
    "marked-highlight": "^2.2.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/vsce": "3.7.1",
    "esbuild": "0.27.3",
    "eslint": "^10.0.2",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "vscode:prepublish": "npm run build -- --production",
    "package": "node -e \"const fs=require('fs');if(fs.existsSync('dist')){for(const f of fs.readdirSync('dist')){if(f.endsWith('.map'))fs.rmSync('dist/'+f,{force:true});}}\" && vsce package",
    "lint": "eslint src/",
    "lint:types": "tsc --noEmit",
    "test": "vitest run"
  }
}
