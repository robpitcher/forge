{
  "name": "forge",
  "displayName": "Forge",
  "description": "AI-powered chat assistant for air-gapped environments using Azure AI Foundry",
  "version": "0.1.0",
  "publisher": "robpitcher",
  "repository": {
    "type": "git",
    "url": "https://github.com/robpitcher/forge"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.93.0",
    "node": ">=20.19.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onView:forge.chatView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forge",
          "title": "Forge",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "forge": [
        {
          "type": "webview",
          "id": "forge.chatView",
          "name": "AI Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "forge.openSettings",
        "title": "Forge Settings",
        "icon": "$(gear)"
      },
      {
        "command": "forge.attachSelection",
        "title": "Forge: Attach Selection"
      },
      {
        "command": "forge.attachFile",
        "title": "Forge: Attach File"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "forge.openSettings",
          "when": "view == forge.chatView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Forge",
      "properties": {
        "forge.copilot.endpoint": {
          "type": "string",
          "default": "",
          "description": "Azure AI Foundry endpoint URL (e.g., https://myresource.openai.azure.com/openai/v1/)"
        },
        "forge.copilot.model": {
          "type": "string",
          "default": "gpt-4.1",
          "description": "Model deployment name"
        },
        "forge.copilot.wireApi": {
          "type": "string",
          "default": "completions",
          "enum": [
            "completions",
            "responses"
          ],
          "description": "API format: 'completions' or 'responses'"
        },
        "forge.copilot.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to Copilot CLI binary (if not on PATH)"
        },
        "forge.copilot.autoApproveTools": {
          "type": "boolean",
          "default": false,
          "description": "Automatically approve tool executions without confirmation. Enable only in trusted environments."
        }
      }
    }
  },
  "dependencies": {
    "@github/copilot-sdk": "0.1.26"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/vsce": "3.7.1",
    "esbuild": "0.27.3",
    "eslint": "^10.0.2",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "package": "npm run build -- --production && vsce package",
    "lint": "eslint src/",
    "lint:types": "tsc --noEmit",
    "test": "vitest run"
  }
}
